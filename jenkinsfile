pipeline {
    agent any

    environment {
        // 'node-20'은 Jenkins Global Tool Configuration에서 설정한 이름과 일치해야 합니다.
        NODEJS_HOME = tool 'Nodejs'
        PATH = "${NODEJS_HOME}/bin:${env.PATH}"
        SLACK_CHANNEL = '#api-test-notifications'
    }

    stages {
        stage('1. 환경 준비') {
            steps {
                echo '>>> 패키지 설치 중...'
                sh 'npm install'
                sh 'npm install -g newman newman-reporter-htmlextra'
            }
        }

        stage('2. 서버 가동') {
            steps {
                echo '>>> 테스트 서버 실행...'
                // fuser로 혹시 떠 있을지 모를 3000포트 프로세스를 미리 정리하고 시작
                sh 'fuser -k 3000/tcp || true'
                sh 'node server.js &'
                sleep 5
            }
        }

        stage('3. 테스트 실행') {
            steps {
                echo '>>> Newman 테스트 시작...'
                sh 'newman run collcetion.json -e env.json -r htmlextra --reporter-htmlextra-export results/api-report.html'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'results/*.html', fingerprint: true
            sh 'fuser -k 3000/tcp || true'
        }
        success {
            slackSend(
                channel: "${SLACK_CHANNEL}",
                color: 'good',
                message: "✅ 빌드 성공! [${env.JOB_NAME} #${env.BUILD_NUMBER}]\n결과 확인: ${env.BUILD_URL}artifact/results/api-report.html"
            )
        }
        failure {
            slackSend(
                channel: "${SLACK_CHANNEL}",
                color: 'danger',
                message: "❌ 빌드 실패! [${env.JOB_NAME} #${env.BUILD_NUMBER}]\n로그 확인: ${env.BUILD_URL}console"
            )
        }
    }
}
